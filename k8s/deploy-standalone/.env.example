# =============================================================================
# OpenAN Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# cp .env.example .env

# =============================================================================
# Database Configuration
# =============================================================================
DB_PASSWORD=openan123

# =============================================================================
# LLM Configuration (Shared)
# =============================================================================
LLM_CHAT_MODEL=deepseek-chat
LLM_CHAT_URL=https://api.deepseek.com/v1/chat/completions

# Registry Center LLM API Keys
REGISTRY_LLM_API_KEY=
REGISTRY_LLM_EMBED_API_KEY=
REGISTRY_LLM_RERANK_API_KEY=

# Orchestration Center LLM API Keys
ORCHESTRATION_LLM_API_KEY=
ORCHESTRATION_A2AT_API_KEY=

# Embedding/Rerank Model Configuration (for Registry Center)
LLM_EMBED_MODEL=bge-m3
LLM_EMBED_URL=
LLM_RERANK_MODEL=bge-reranker-v2-m3
LLM_RERANK_URL=

# A2AT SDK Configuration (for Orchestration Center)
A2AT_LLM_PROVIDER=deepseek
A2AT_LLM_MODEL=deepseek-chat
A2AT_LLM_BASE_URL=https://api.deepseek.com

# =============================================================================
# Image Configuration (Optional)
# =============================================================================
# REGISTRY_SRC=../../registry-center
# REGISTRY_TAG=latest
# ORCHESTRATION_SRC=..
